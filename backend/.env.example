# Copy this file to .env and fill in real values

# Required: ImgBB API key for in-email image hosting
IMGBB_API_KEY=your_imgbb_api_key_here

# Required in production: Cloudflare Turnstile secret key
# Get one free at https://dash.cloudflare.com/?to=/:account/turnstile
# Defaults to Cloudflare's "always passes" test secret if unset (DO NOT use in prod).
TURNSTILE_SECRET=your_turnstile_secret_here

# Optional: set to "development" to expose /docs and /openapi.json (default: production)
ENV=production
