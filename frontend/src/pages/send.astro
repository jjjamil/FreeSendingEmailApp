---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/site/Nav.astro'
import Footer from '../components/site/Footer.astro'
import SendForm from '../components/SendForm.jsx'
import { Mail, FileSpreadsheet, Zap, ShieldCheck } from 'lucide-react'

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://sendanemail.xyz/' },
    { '@type': 'ListItem', position: 2, name: 'Send', item: 'https://sendanemail.xyz/send' },
  ],
}

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to send bulk emails free using Gmail',
  description: 'Send personalized bulk emails through your own Gmail account in three steps.',
  totalTime: 'PT5M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Connect your Gmail',
      text: 'Enter your Gmail address and a Gmail App Password generated from your Google account security settings.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Add recipients',
      text: 'Upload a CSV file with email and name columns, or add recipients manually row by row.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Write and send',
      text: 'Compose your email using the rich-text editor with the {Name} placeholder for personalization, then hit Send.',
    },
  ],
}

const features = [
  { Icon: Mail, label: 'Personalized {Name}' },
  { Icon: FileSpreadsheet, label: 'CSV or Manual' },
  { Icon: Zap, label: 'Smart Batches' },
  { Icon: ShieldCheck, label: 'No credentials stored' },
]
---

<Layout
  title="Send Bulk Emails — Free Gmail Email Sender"
  description="Send personalized bulk emails using your own Gmail. Upload a CSV or add recipients manually, write your message, and send in minutes — completely free."
  jsonLd={[breadcrumbJsonLd, howToJsonLd]}
>
  <Nav current="/send" />

  <main class="relative">
    <div class="blob bg-brand-200 w-80 h-80 -top-12 -left-24"></div>
    <div class="blob bg-fuchsia-200 w-96 h-96 -bottom-24 -right-24"></div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 pt-10 pb-16">
      <!-- Hero -->
      <div class="text-center mb-10">
        <span class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-brand-gradient text-white shadow-brand mb-5">
          <Mail className="w-6 h-6" strokeWidth={2.4} aria-hidden="true" />
        </span>

        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight">
          Send Bulk Emails <span class="text-brand-gradient">via Your Gmail</span>
        </h1>
        <p class="mt-3 text-sm sm:text-base text-gray-600 max-w-xl mx-auto leading-relaxed">
          Free, no sign-up. Upload your list, write your message, and send. Your credentials are never stored.
        </p>

        <ul class="flex flex-wrap justify-center gap-2 mt-5">
          {features.map(({ Icon, label }) => (
            <li class="inline-flex items-center gap-1.5 bg-white text-gray-700 text-xs font-medium px-3 py-1.5 rounded-full shadow-sm border border-gray-100">
              <Icon className="w-3.5 h-3.5 text-brand-600" strokeWidth={2.2} aria-hidden="true" />
              {label}
            </li>
          ))}
        </ul>
      </div>

      <SendForm client:load />
    </div>
  </main>

  <Footer />
</Layout>
