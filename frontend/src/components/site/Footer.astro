---
import { Mail, Heart } from 'lucide-react'
import { USE_CASES } from '../../data/useCases'

const year = new Date().getFullYear()
---

<footer class="border-t border-gray-100 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-10">
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-3">
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-brand-gradient shadow-brand">
            <Mail className="w-5 h-5 text-white" strokeWidth={2.4} aria-hidden="true" />
          </span>
          <span class="font-bold text-gray-900 text-sm">Free Sending Email</span>
        </a>
        <p class="text-xs text-gray-500 leading-relaxed">
          Send personalized bulk emails free using your own Gmail. No sign-up, no fees.
        </p>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">Product</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-gray-600 hover:text-brand-700">Home</a></li>
          <li><a href="/send" class="text-gray-600 hover:text-brand-700">Send Emails</a></li>
          <li><a href="/#how-it-works" class="text-gray-600 hover:text-brand-700">How It Works</a></li>
          <li><a href="/#faq" class="text-gray-600 hover:text-brand-700">FAQ</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">Use Cases</h3>
        <ul class="space-y-2 text-sm">
          {USE_CASES.slice(0, 4).map((uc) => (
            <li>
              <a href={`/use-cases/${uc.slug}`} class="text-gray-600 hover:text-brand-700">
                {uc.shortTitle}
              </a>
            </li>
          ))}
          <li><a href="/use-cases" class="text-brand-700 font-medium hover:underline">View all →</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">Resources</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="https://myaccount.google.com/apppasswords"
              target="_blank"
              rel="noopener"
              class="text-gray-600 hover:text-brand-700"
            >
              Get Gmail App Password
            </a>
          </li>
          <li>
            <a
              href="https://support.google.com/mail/answer/22839"
              target="_blank"
              rel="noopener"
              class="text-gray-600 hover:text-brand-700"
            >
              Gmail sending limits
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-200 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-gray-500">
        © {year} Free Sending Email — Free forever. Your credentials are never stored.
      </p>
      <p class="text-xs text-gray-400 inline-flex items-center gap-1">
        Built with <Heart className="w-3 h-3 text-rose-500 fill-rose-500" aria-hidden="true" /> for senders who don't want a subscription.
      </p>
    </div>
  </div>
</footer>
